{
  "name": "student-risk-backend",
  "version": "1.0.0",
  "description": "Student At-Risk Analysis System — Backend API",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "pm2":     "pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js",
    "db:setup": "mysql -u root -p student_risk_db < ../database/schema.sql"
  },
  "dependencies": {
    "bcrypt":            "^5.1.1",
    "bull":              "^4.12.2",
    "compression":       "^1.7.4",
    "cookie-parser":     "^1.4.6",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "morgan":            "^1.10.0",
    "multer":            "^1.4.5-lts.1",
    "mysql2":            "^3.9.7",
    "node-cron":         "^3.0.3",
    "nodemailer":        "^6.9.13",
    "pdfkit":            "^0.15.0",
    "redis":             "^4.6.14",
    "socket.io":         "^4.7.5",
    "xlsx":              "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
